# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/travel_agency?schema=public"

# Server
PORT=5000
NODE_ENV=development

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Stripe (use test keys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Anthropic (Claude) — optional; planner falls back to rule-based when unset
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Email notifications (SMTP) — optional. When unset, emails are logged to console.
# Tested with Gmail (use an app password) and Mailtrap for dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
MAIL_FROM=ATLAS Travel <noreply@atlas.com>

# Booking.com15 via RapidAPI — optional. When unset or false, search uses
# only the seeded DB inventory (no LIVE badges).
EXTERNAL_INVENTORY_ENABLED=false
RAPIDAPI_KEY=
RAPIDAPI_HOST=booking-com15.p.rapidapi.com
